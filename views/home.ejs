            </div>
            <div class="reviews-summary-bars">
                <div class="bar-row"><span>Cleanliness</span><div class="bar"><div class="bar-fill" style="--w:98%"></div></div><span>9.8</span></div>
                <div class="bar-row"><span>Service</span><div class="bar"><div class="bar-fill" style="--w:95%"></div></div><span>9.5</span></div>
                <div class="bar-row"><span>Location</span><div class="bar"><div class="bar-fill" style="--w:92%"></div></div><span>9.2</span></div>
                <div class="bar-row"><span>Value</span><div class="bar"><div class="bar-fill" style="--w:90%"></div></div><span>9.0</span></div>
