            <p class="section-subtitle">Discover our exquisite room collection, each designed for unparalleled comfort and elegance.</p>
        </div>

        <div class="rooms-grid">
            <!-- Deluxe Room -->
            <div class="room-card">
                <div class="room-image">
                    <img src="https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=600&h=400&fit=crop" alt="Deluxe Room">
                    <div class="room-image-overlay">
                        <button class="btn btn-ghost">View Details</button>
                    </div>
                    <div class="room-badge">From $250</div>
                    <div class="room-type-tag">Deluxe</div>
                </div>
                <div class="room-info">
                    <h3>Deluxe Room</h3>
                    <p class="room-description">Spacious room with premium amenities and breathtaking city views, perfect for solo or couple stays.</p>
                    <ul class="room-features">
                        <li><i class="fas fa-wifi"></i> High-Speed WiFi</li>
                        <li><i class="fas fa-tv"></i> 55" Smart TV</li>
                        <li><i class="fas fa-bath"></i> Luxury Bath</li>
                        <li><i class="fas fa-snowflake"></i> Climate Control</li>
                    </ul>
                    <div class="room-footer">
                        <span class="room-price">$250 <small>/night</small></span>
                        <button class="btn-reserve" data-room="Deluxe Room">Reserve</button>
                    </div>
                </div>
            </div>

            <!-- Standard Room -->
            <div class="room-card">
                <div class="room-image">
                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?w=600&h=400&fit=crop" alt="Standard Room">
                    <div class="room-image-overlay">
                        <button class="btn btn-ghost">View Details</button>
                    </div>
                    <div class="room-badge">From $150</div>
                    <div class="room-type-tag">Standard</div>
                </div>
                <div class="room-info">
                    <h3>Standard Room</h3>
                    <p class="room-description">Well-appointed room with all essentials for a comfortable and relaxing stay at a great value.</p>
                    <ul class="room-features">
                        <li><i class="fas fa-wifi"></i> Free WiFi</li>
                        <li><i class="fas fa-tv"></i> Smart TV</li>
                        <li><i class="fas fa-coffee"></i> Tea & Coffee</li>
                        <li><i class="fas fa-snowflake"></i> Air Conditioning</li>
                    </ul>
                    <div class="room-footer">
                        <span class="room-price">$150 <small>/night</small></span>
                        <button class="btn-reserve" data-room="Standard Room">Reserve</button>
                    </div>
                </div>
            </div>

            <!-- Family Suite -->
            <div class="room-card room-card--featured">
                <div class="room-image">
                    <img src="https://images.unsplash.com/photo-1729605412224-147d072d3667?q=80&w=1170&auto=format&fit=crop" alt="Family Suite">
                    <div class="room-image-overlay">
                        <button class="btn btn-ghost">View Details</button>
                    </div>
                    <div class="room-badge room-badge--gold">From $400</div>
                    <div class="room-type-tag room-type-tag--gold">Family Suite</div>
                </div>
                <div class="room-info">
                    <h3>Family Suite</h3>
                    <p class="room-description">Spacious suite with separate living area and two bedrooms, ideal for families and extended stays.</p>
                    <ul class="room-features">
                        <li><i class="fas fa-users"></i> Sleeps up to 5</li>
                        <li><i class="fas fa-couch"></i> Living Room</li>
                        <li><i class="fas fa-utensils"></i> Kitchenette</li>
                        <li><i class="fas fa-crown"></i> Premium Amenities</li>
                    </ul>
                    <div class="room-footer">
                        <span class="room-price">$400 <small>/night</small></span>
                        <button class="btn-reserve" data-room="Family Suite">Reserve</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

